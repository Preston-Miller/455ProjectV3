<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head') %>
  </head>
  <body>
    <div class="wrap">
      <nav class="nav">
        <a href="/">Home</a>
        <a href="/order">Place order</a>
        <a href="/admin">Admin</a>
      </nav>
      <h1><%= title %></h1>
      <p class="muted" style="margin-bottom: 1rem">
        Enter one <strong>orders</strong> row. Totals are entered directly (no line items in this version).
      </p>

      <% if (success) { %>
      <div class="banner ok">Order saved.</div>
      <% } %>
      <% if (error) { %>
      <div class="banner err"><%= error %></div>
      <% } %>

      <form method="post" action="/order">
        <div class="row">
          <label for="customer_id">Customer</label>
          <select id="customer_id" name="customer_id" required>
            <option value="">— Select —</option>
            <% customers.forEach(function (c) { %>
            <option value="<%= c.customer_id %>" <%= String(values.customer_id) === String(c.customer_id) ? 'selected' : '' %>><%= c.customer_id %> — <%= c.full_name %> (<%= c.email %>)</option>
            <% }) %>
          </select>
        </div>

        <div class="row">
          <label for="order_datetime">Order date / time</label>
          <input
            id="order_datetime"
            name="order_datetime"
            type="datetime-local"
            required
            value="<%= values.order_datetime || defaultOrderDatetime %>"
          />
        </div>

        <div class="row">
          <label for="billing_zip">Billing ZIP</label>
          <input id="billing_zip" name="billing_zip" type="text" value="<%= values.billing_zip || '' %>" />
        </div>
        <div class="row">
          <label for="shipping_zip">Shipping ZIP</label>
          <input id="shipping_zip" name="shipping_zip" type="text" value="<%= values.shipping_zip || '' %>" />
        </div>
        <div class="row">
          <label for="shipping_state">Shipping state</label>
          <input id="shipping_state" name="shipping_state" type="text" value="<%= values.shipping_state || '' %>" />
        </div>

        <div class="row">
          <label for="payment_method">Payment method</label>
          <select id="payment_method" name="payment_method" required>
            <% ['card','paypal','bank','crypto'].forEach(function (p) { %>
            <option value="<%= p %>" <%= values.payment_method === p ? 'selected' : (!values.payment_method && p === 'card' ? 'selected' : '') %>><%= p %></option>
            <% }) %>
          </select>
        </div>

        <div class="row">
          <label for="device_type">Device type</label>
          <select id="device_type" name="device_type" required>
            <% ['mobile','desktop','tablet'].forEach(function (d) { %>
            <option value="<%= d %>" <%= values.device_type === d ? 'selected' : (!values.device_type && d === 'desktop' ? 'selected' : '') %>><%= d %></option>
            <% }) %>
          </select>
        </div>

        <div class="row">
          <label for="ip_country">IP country (e.g. US)</label>
          <input id="ip_country" name="ip_country" type="text" required value="<%= values.ip_country || 'US' %>" />
        </div>

        <div class="row">
          <label><input type="checkbox" name="promo_used" value="1" <%= values.promo_used === '1' ? 'checked' : '' %> /> Promo used</label>
        </div>
        <div class="row">
          <label for="promo_code">Promo code</label>
          <input id="promo_code" name="promo_code" type="text" value="<%= values.promo_code || '' %>" />
        </div>

        <div class="row">
          <label for="order_subtotal">Order subtotal</label>
          <input id="order_subtotal" name="order_subtotal" type="number" step="any" required value="<%= values.order_subtotal != null ? values.order_subtotal : '' %>" />
        </div>
        <div class="row">
          <label for="shipping_fee">Shipping fee</label>
          <input id="shipping_fee" name="shipping_fee" type="number" step="any" required value="<%= values.shipping_fee != null ? values.shipping_fee : '' %>" />
        </div>
        <div class="row">
          <label for="tax_amount">Tax amount</label>
          <input id="tax_amount" name="tax_amount" type="number" step="any" required value="<%= values.tax_amount != null ? values.tax_amount : '' %>" />
        </div>
        <div class="row">
          <label for="order_total">Order total</label>
          <input id="order_total" name="order_total" type="number" step="any" required value="<%= values.order_total != null ? values.order_total : '' %>" />
        </div>

        <button type="submit">Submit order</button>
      </form>
    </div>
  </body>
</html>
